{
    "$schema": "https://turborepo.com/schema.json",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": [
                ".next/**",
                "!.next/cache/**",
                "dist/**",
                "build/**",
                "bin/**"
            ]
        },
        "check-types": {
            "dependsOn": ["^check-types"]
        },
        "dev": {
            "persistent": true,
            "cache": false,
            "env": ["GOCACHE", "LOCALAPPDATA"]
        },
        "test": {
            "dependsOn": ["^test"]
        }
    }
}